            "path": "pyproject.toml",
            "regex": "(?m)^\\s*\\[tool\\.pytest\\.ini_options\\]\\s*$"
          }
        },
        {
          "file_contains": {
            "path": "requirements.txt",
            "regex": "(?im)^\\s*pytest([<>=~!\\[]|\\s|$)"
          }
        },
        {
          "file_contains": {
            "path": "requirements-dev.txt",
            "regex": "(?im)^\\s*pytest([<>=~!\\[]|\\s|$)"
